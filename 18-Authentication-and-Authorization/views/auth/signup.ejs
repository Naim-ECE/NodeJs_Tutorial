<%- include("../partials/head") %>
  <body>
    <%- include("../partials/nav") %>
    <header class="text-center mt-10">
      <h1 class="text-3xl font-bold text-gray-900 tracking-tight">Create Your Account</h1>
      <p class="text-gray-500 text-sm mt-2">Join us today and start your journey</p>
    </header>

    <main class="max-w-md mx-auto mt-10 px-4 pb-8">
      <form
        action="/signup"
        method="POST"
        class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100 transition-shadow hover:shadow-xl duration-300"
      >
        <!-- Name Section -->
        
        <% if(typeof errors !== 'undefined' && errors.length > 0 && errors) { %>
          <div class="text-red-500 text-sm mb-2 bg-red-100 p-3 rounded-lg border border-red-200">
              <% errors.forEach((error) => { %>
                <p><%= error %></p>
                <% }); %>
            </div>
            <br />
            <% } %>
          
          <div class="grid grid-cols-2 gap-4 mb-5">

          <input
            type="text"
            name="firstName"
            placeholder="First Name"
            value="<%= oldInput.firstName ? oldInput.firstName : "" %>"
            class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none
                   focus:ring-2 focus:ring-red-400 focus:border-transparent transition-all duration-200 bg-gray-50 hover:bg-white"
            required
          />

          <input
            type="text"
            name="lastName"
            placeholder="Last Name"
            value="<%= oldInput.lastName ? oldInput.lastName : "" %>"
            class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none
                   focus:ring-2 focus:ring-red-400 focus:border-transparent transition-all duration-200 bg-gray-50 hover:bg-white"
          />
        </div>

        <!-- Email Section -->
        <input
          type="email"
          name="email"
          placeholder="Email Address"
          value="<%= oldInput.email ? oldInput.email : "" %>"
          class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none
                 focus:ring-2 focus:ring-red-400 focus:border-transparent transition-all duration-200 mb-5 bg-gray-50 hover:bg-white"
          required
        />

        <!-- Password Section -->
        <input
          type="password"
          name="password"
          placeholder="Password"
          class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none
                 focus:ring-2 focus:ring-red-400 focus:border-transparent transition-all duration-200 mb-5 bg-gray-50 hover:bg-white"
          required
        />

        <input
          type="password"
          name="confirmedPassword"
          placeholder="Confirm Password"
          class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none
                 focus:ring-2 focus:ring-red-400 focus:border-transparent transition-all duration-200 mb-6 bg-gray-50 hover:bg-white"
          required
        />

        <!-- User Type Section -->
        <div class="mb-6">
          <p class="font-semibold mb-4 text-sm uppercase tracking-wide text-gray-700">Select Your Role</p>
          
          <div class="space-y-3">
            <label class="flex items-center p-3 border border-gray-200 rounded-lg cursor-pointer hover:bg-red-50 transition-colors duration-200 group">
              <input 
                type="radio" 
                name="userType" 
                value="host" 
                id="host"
                class="accent-red-500 w-5 h-5"
                checked="<%= oldInput.userType === 'host' ? 'checked' : '' %>"
              />
              <span class="text-gray-700 font-medium ml-3 group-hover:text-red-600 transition-colors">Property Host</span>
            </label>

            <label class="flex items-center p-3 border border-gray-200 rounded-lg cursor-pointer hover:bg-red-50 transition-colors duration-200 group">
              <input 
                type="radio" 
                name="userType" 
                value="guest" 
                id="guest"
                class="accent-red-500 w-5 h-5"
                checked="<%= oldInput.userType === 'guest' ? 'checked' : '' %>"
              />
              <span class="text-gray-700 font-medium ml-3 group-hover:text-red-600 transition-colors">Guest</span>
            </label>
          </div>
        </div>

        <!-- Terms Section -->
        <div class="flex items-start gap-3 mb-7 p-3 bg-gray-50 rounded-lg">
          <input 
            type="checkbox" 
            name="terms" 
            id="terms"
            required
            class="accent-red-500 w-5 h-5 mt-0.5 shrink-0 cursor-pointer"
          />
          <label for="terms" class="text-sm text-gray-700 leading-relaxed">
            I agree to the <span class="font-semibold text-red-500 cursor-pointer hover:text-red-600 transition-colors">terms and conditions</span>
          </label>
        </div>

        <!-- Submit Button -->
        <input
          type="submit"
          value="Create Account"
          class="w-full mt-2 bg-linear-to-r from-red-500 to-red-600 text-white font-semibold py-3 rounded-lg
                 hover:from-red-600 hover:to-red-700 active:from-red-700 active:to-red-800 transition-all duration-200 cursor-pointer shadow-md hover:shadow-lg transform"
        />

        <!-- Login Link -->
        <div class="text-center mt-7">
          <p class="text-sm text-gray-600">
            Already have an account?
            <a href="/login" class="text-red-500 font-semibold hover:text-red-600 transition-colors duration-200">
              Sign In
            </a>
          </p>
        </div>
      </form>
    </main>

  </body>
</html>
