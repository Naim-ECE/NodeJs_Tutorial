<%- include('../partials/head') %>
  </head>
  <body>
      <%- include('../partials/nav') %>
      <main class="container mx-auto px-4 mt-10 mb-10">
          <div class="bg-linear-to-br from-white to-gray-50 shadow-2xl rounded-2xl overflow-hidden max-w-6xl mx-auto">
              <div class="bg-linear-to-r from-red-500 to-red-600 px-8 py-6">
                  <h2 class="text-4xl font-bold text-white text-center drop-shadow-lg">
                      🏠 <%= home.houseName %>
                  </h2>
              </div>
              
              <div class="p-8 md:p-10">
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                      <!-- Image Section -->
                      <div class="flex flex-col justify-center">
                          <div class="rounded-2xl overflow-hidden shadow-xl hover:shadow-2xl transition-shadow duration-300 border-4 border-gray-100">
                              <img 
                                  src="<%= home.photo %>" 
                                  alt="<%= home.name %>" 
                                  class="w-full h-96 object-cover hover:scale-105 transition-transform duration-300"
                              >
                          </div>
                      </div>
                      
                      <!-- Details Section -->
                      <div class="space-y-6">
                          <!-- Description -->
                          <div class="bg-blue-50 rounded-xl p-6 border-l-4 border-blue-500 hover:shadow-md transition-shadow duration-200">
                              <h3 class="text-xl font-bold text-blue-900 mb-3 flex items-center">
                                  📝 Description
                              </h3>
                              <p class="text-gray-700 leading-relaxed"><%= home.description %></p>
                          </div>

                          <!-- Location -->
                          <div class="bg-green-50 rounded-xl p-6 border-l-4 border-green-500 hover:shadow-md transition-shadow duration-200">
                              <h3 class="text-xl font-bold text-green-900 mb-3 flex items-center">
                                  📍 Location
                              </h3>
                              <p class="text-gray-700 leading-relaxed"><%= home.location %></p>
                          </div>
                          
                          <!-- Price -->
                          <div class="bg-linear-to-r from-purple-50 to-pink-50 rounded-xl p-6 border-l-4 border-purple-500 hover:shadow-md transition-shadow duration-200">
                              <h3 class="text-xl font-bold text-purple-900 mb-3 flex items-center">
                                  💰 Price per Night
                              </h3>
                              <p class="text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-purple-600 to-pink-600">
                                  <%= home.price %> BDT
                              </p>
                          </div>
                          
                          <!-- Rating -->
                          <div class="bg-yellow-50 rounded-xl p-6 border-l-4 border-yellow-500 hover:shadow-md transition-shadow duration-200">
                              <h3 class="text-xl font-bold text-yellow-900 mb-3 flex items-center">
                                  ⭐ Rating
                              </h3>
                              <div class="flex items-center space-x-3">
                                <div class="flex space-x-1">
                                    <% for (let i = 1; i <= 5; i++) { %>
                                        <span class="text-2xl <%= i <= Math.floor(home.rating) ? 'text-yellow-400' : 'text-gray-300' %>">★</span>
                                    <% } %>
                                </div>
                                <span class="text-lg font-semibold text-gray-700"><%= home.rating %> / 5.0
                                </span>
                              </div>
                            </div>
                            <div class="bg-red-50 rounded-xl p-6 border-l-4 border-red-500 hover:shadow-md transition-shadow duration-200">
                            <h3 class="text-xl font-bold text-red-900 mb-3 flex items-center">
                                📄 House Rules
                            </h3>
                                <a href="/rules/<%= home._id %>"
                                    class="inline-flex items-center gap-2 px-4 py-2 bg-red-500 text-white rounded-lg text-sm font-medium hover:bg-red-600 transition-colors">
                                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M8 1v9M4.5 7l3.5 3.5L11.5 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M2 12.5h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                    </svg>
                                    Download house rules
                                </a>
                            </div>

                          <!-- Favourite Button -->
                          <div class="pt-4">
                              <%- include('../partials/favourite') %>
                          </div>
                      </div>
                  </div>
              </div>
          </div>
      </main>
  </body>
</html>